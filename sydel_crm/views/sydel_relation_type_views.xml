<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- sydel.relation.type — Liste                                   -->
    <!-- ============================================================ -->
    <record id="sydel_relation_type_view_list" model="ir.ui.view">
        <field name="name">sydel.relation.type.list</field>
        <field name="model">sydel.relation.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="forward_label"/>
                <field name="reverse_label"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- sydel.relation.type — Formulaire                              -->
    <!-- ============================================================ -->
    <record id="sydel_relation_type_view_form" model="ir.ui.view">
        <field name="name">sydel.relation.type.form</field>
        <field name="model">sydel.relation.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="forward_label"/>
                        </group>
                        <group>
                            <field name="reverse_label"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Action                                                        -->
    <!-- ============================================================ -->
    <record id="sydel_relation_type_action" model="ir.actions.act_window">
        <field name="name">Types de relations</field>
        <field name="res_model">sydel.relation.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>

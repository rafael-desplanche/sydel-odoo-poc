<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sydel_company_director_view_list" model="ir.ui.view">
        <field name="name">sydel.company.director.list</field>
        <field name="model">sydel.company.director</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="director_id"/>
                <field name="role"/>
                <field name="role_other" column_invisible="1"/>
                <field name="start_date"/>
                <field name="end_date"/>
            </list>
        </field>
    </record>

</odoo>

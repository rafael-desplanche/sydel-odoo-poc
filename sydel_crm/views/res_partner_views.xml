<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- res.partner — Héritage du formulaire                          -->
    <!-- ============================================================ -->
    <record id="res_partner_view_form_inherit_sydel_crm" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.sydel.crm</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">

            <!-- ===== Bouton stat "Envoyer un email" dans le header ===== -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_send_email"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-envelope"
                        invisible="not email">
                    <span>Envoyer un email</span>
                </button>
            </xpath>

            <!-- ===== Prénom à côté du nom ===== -->
            <xpath expr="//field[@name='company_type']" position="after">
                <field name="firstname"
                       placeholder="Prénom"
                       invisible="is_company"/>
            </xpath>

            <!-- ===== Bloc personne physique — après les champs natifs ===== -->
            <xpath expr="//page[@name='internal_notes']" position="before">

                <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
                <!-- ONGLET : Identité personne physique                     -->
                <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
                <page string="Identité" name="page_identity_physical"
                      invisible="is_company">
                    <group>
                        <group string="État civil">
                            <field name="gender"/>
                            <field name="birthdate"/>
                            <field name="age" readonly="1"/>
                            <field name="birth_city"/>
                            <field name="birth_department"/>
                            <field name="nationality_id"/>
                        </group>
                        <group string="Situation personnelle">
                            <field name="marital_status"/>
                            <field name="matrimonial_regime"
                                   invisible="marital_status != 'married'"/>
                            <field name="is_owner"/>
                            <field name="revenue"/>
                        </group>
                    </group>
                    <group>
                        <group string="Informations professionnelles">
                            <field name="rpps_number"
                                   placeholder="11 chiffres"/>
                            <field name="ordre_number"
                                   placeholder="9 chiffres"/>
                        </group>
                        <group string="Filiation">
                            <field name="father_name"/>
                            <field name="mother_name"/>
                        </group>
                    </group>
                </page>

                <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
                <!-- ONGLET : Identité personne morale                       -->
                <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
                <page string="Identité société" name="page_identity_company"
                      invisible="not is_company">
                    <group>
                        <group string="Informations légales">
                            <field name="legal_form"/>
                            <field name="legal_form_other"
                                   invisible="legal_form != 'other'"/>
                            <field name="corporate_purpose"/>
                            <field name="rcs_city"
                                   placeholder="Ville d'immatriculation"/>
                        </group>
                        <group string="Numéros d'identification">
                            <field name="siren" placeholder="9 chiffres"/>
                            <field name="siret" placeholder="14 chiffres"/>
                            <field name="naf_code" placeholder="Ex: 6920Z"/>
                            <field name="vat" placeholder="Ex: FR12823456789"/>
                        </group>
                    </group>
                </page>

                <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
                <!-- ONGLET : Capital social (personne morale)               -->
                <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
                <page string="Capital social" name="page_capital"
                      invisible="not is_company">
                    <group>
                        <group>
                            <field name="share_capital"/>
                            <field name="total_shares"/>
                            <field name="share_value" readonly="1"/>
                        </group>
                    </group>
                    <separator string="Répartition du capital"/>
                    <field name="capital_share_ids">
                        <list editable="bottom">
                            <field name="shareholder_id"/>
                            <field name="share_percentage"/>
                            <field name="share_count"/>
                            <field name="share_amount" readonly="1"/>
                            <field name="currency_id" column_invisible="1"/>
                        </list>
                    </field>
                    <separator string="Dirigeants"/>
                    <field name="director_ids">
                        <list editable="bottom">
                            <field name="director_id"/>
                            <field name="role"/>
                            <field name="role_other"
                                   column_invisible="1"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </list>
                    </field>
                </page>

                <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
                <!-- ONGLET : Relations (toile des liens)                    -->
                <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
                <page string="Relations" name="page_relations">
                    <field name="relation_ids">
                        <list editable="bottom">
                            <field name="related_partner_id"/>
                            <field name="relation_type_id"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="notes"/>
                        </list>
                    </field>
                </page>

                <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
                <!-- ONGLET : Documents                                      -->
                <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
                <page string="Documents" name="page_documents">
                    <field name="document_ids">
                        <list>
                            <field name="name"/>
                            <field name="document_type"/>
                            <field name="filename"/>
                            <field name="upload_date"/>
                            <field name="uploaded_by_id"/>
                        </list>
                    </field>
                </page>

                <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
                <!-- ONGLET : Opportunités                                   -->
                <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
                <page string="Opportunités" name="page_opportunities">
                    <field name="opportunity_ids">
                        <list>
                            <field name="name"/>
                            <field name="mission_type"/>
                            <field name="stage_id"/>
                            <field name="next_action_date"/>
                        </list>
                    </field>
                </page>

            </xpath>

            <!-- ===== Onglet Notes existant → on le renomme ===== -->
            <xpath expr="//page[@name='internal_notes']" position="attributes">
                <attribute name="string">Notes</attribute>
            </xpath>

            <!-- ===== Champ notes Sydel dans l'onglet Notes ===== -->
            <xpath expr="//page[@name='internal_notes']//field[@name='comment']"
                   position="before">
                <separator string="Notes Sydel"/>
                <field name="contact_note"
                       placeholder="Pense-bête, alertes, informations importantes sur ce contact..."/>
                <separator string="Notes internes Odoo"/>
            </xpath>

            <!-- ===== Suivi — après les tags natifs ===== -->
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="assigned_user_ids"
                       widget="many2many_tags"
                       placeholder="Utilisateurs référents"/>
                <field name="acquisition_source"/>
                <field name="last_interaction_date" readonly="1"/>
            </xpath>

        </field>
    </record>

    <!-- ============================================================ -->
    <!-- res.partner — Héritage de la liste                            -->
    <!-- ============================================================ -->
    <record id="res_partner_view_list_inherit_sydel_crm" model="ir.ui.view">
        <field name="name">res.partner.list.inherit.sydel.crm</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='display_name']" position="after">
                <field name="firstname" optional="show"/>
                <field name="legal_form" optional="hide"/>
                <field name="corporate_purpose" optional="hide"/>
                <field name="assigned_user_ids" widget="many2many_tags" optional="show"/>
                <field name="last_interaction_date" optional="show"/>
                <field name="acquisition_source" optional="hide"/>
            </xpath>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- res.partner — Héritage de la recherche                        -->
    <!-- ============================================================ -->
    <record id="res_partner_view_search_inherit_sydel_crm" model="ir.ui.view">
        <field name="name">res.partner.search.inherit.sydel.crm</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='type_company']" position="after">
                <filter name="filter_my_contacts"
                        string="Mes contacts"
                        domain="[('assigned_user_ids', 'in', [uid])]"/>
                <filter name="filter_physical"
                        string="Personnes physiques"
                        domain="[('is_company', '=', False)]"/>
                <filter name="filter_moral"
                        string="Personnes morales"
                        domain="[('is_company', '=', True)]"/>
                <filter name="groupby_source"
                        string="Source d'acquisition"
                        context="{'group_by': 'acquisition_source'}"/>
                <filter name="groupby_legal_form"
                        string="Forme juridique"
                        context="{'group_by': 'legal_form'}"/>
            </xpath>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Action spécifique Sydel Contacts                              -->
    <!-- ============================================================ -->
    <record id="sydel_contacts_action" model="ir.actions.act_window">
        <field name="name">Contacts</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="context">{'default_is_company': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créer un nouveau contact
            </p>
            <p>
                Ajoutez vos contacts personnes physiques et morales
                pour gérer votre portefeuille client.
            </p>
        </field>
    </record>

</odoo>

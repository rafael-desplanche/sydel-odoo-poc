<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sydel_contact_relation_view_list" model="ir.ui.view">
        <field name="name">sydel.contact.relation.list</field>
        <field name="model">sydel.contact.relation</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="related_partner_id"/>
                <field name="relation_type_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

</odoo>

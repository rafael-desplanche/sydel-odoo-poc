<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="stage_discovery" model="crm.stage">
        <field name="name">Appel de découverte</field>
        <field name="sequence">10</field>
        <field name="is_won">False</field>
    </record>

    <record id="stage_r1" model="crm.stage">
        <field name="name">R1 — Premier rendez-vous</field>
        <field name="sequence">20</field>
        <field name="is_won">False</field>
    </record>

    <record id="stage_r2" model="crm.stage">
        <field name="name">R2 — Deuxième rendez-vous</field>
        <field name="sequence">30</field>
        <field name="is_won">False</field>
    </record>

    <record id="stage_letter_sent" model="crm.stage">
        <field name="name">Lettre de mission envoyée</field>
        <field name="sequence">40</field>
        <field name="is_won">False</field>
    </record>

    <record id="stage_letter_signed" model="crm.stage">
        <field name="name">Lettre de mission signée</field>
        <field name="sequence">50</field>
        <field name="is_won">True</field>
    </record>

    <record id="stage_letter_not_signed" model="crm.stage">
        <field name="name">Lettre de mission non signée</field>
        <field name="sequence">60</field>
        <field name="is_won">False</field>
    </record>

</odoo>

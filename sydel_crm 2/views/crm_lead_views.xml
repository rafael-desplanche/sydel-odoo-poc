<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- crm.lead — Héritage du formulaire                             -->
    <!-- ============================================================ -->
    <record id="crm_lead_view_form_inherit_sydel_crm" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.sydel.crm</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <!-- Champs mission dans l'onglet principal -->
            <xpath expr="//group[@name='pl_left']" position="inside">
                <field name="mission_type"/>
            </xpath>

            <xpath expr="//group[@name='pl_right']" position="inside">
                <field name="next_action_date"/>
                <field name="next_action_note"
                       placeholder="Ex: Relancer par téléphone"/>
            </xpath>

            <!-- Champs lettre de mission — nouvel onglet -->
            <xpath expr="//page[@name='extra']" position="after">
                <page string="Lettre de mission" name="page_mission_letter">
                    <group>
                        <group>
                            <field name="mission_letter_sent_date"/>
                        </group>
                        <group>
                            <field name="mission_letter_signed_date"/>
                        </group>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

    <!-- ============================================================ -->
    <!-- crm.lead — Héritage de la liste                               -->
    <!-- ============================================================ -->
    <record id="crm_lead_view_list_inherit_sydel_crm" model="ir.ui.view">
        <field name="name">crm.lead.list.inherit.sydel.crm</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_leads"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='stage_id']" position="after">
                <field name="mission_type" optional="show"/>
                <field name="next_action_date" optional="show"
                       decoration-danger="next_action_date &lt; current_date"/>
            </xpath>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- crm.lead — Héritage de la recherche                           -->
    <!-- ============================================================ -->
    <record id="crm_lead_view_search_inherit_sydel_crm" model="ir.ui.view">
        <field name="name">crm.lead.search.inherit.sydel.crm</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.view_crm_case_opportunities_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//group" position="inside">
                <filter name="groupby_mission_type"
                        string="Type de mission"
                        context="{'group_by': 'mission_type'}"/>
            </xpath>
            <xpath expr="//filter[@name='myopportunities']" position="after">
                <separator/>
                <filter name="filter_overdue_action"
                        string="Relance en retard"
                        domain="[('next_action_date', '&lt;', context_today().strftime('%%Y-%%m-%%d'))]"/>
            </xpath>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Action Pipeline Sydel                                         -->
    <!-- ============================================================ -->
    <record id="sydel_crm_lead_action" model="ir.actions.act_window">
        <field name="name">Pipeline</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{
            'default_type': 'opportunity',
            'search_default_assigned_to_me': 1,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créer une nouvelle opportunité
            </p>
        </field>
    </record>

</odoo>

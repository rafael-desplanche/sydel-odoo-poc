<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sydel_contact_shareholding_list" model="ir.ui.view">
        <field name="name">sydel.contact.shareholding.list</field>
        <field name="model">sydel.contact.shareholding</field>
        <field name="arch" type="xml">
            <list>
                <field name="shareholder_partner_id"/>
                <field name="company_partner_id"/>
                <field name="percentage"/>
                <field name="shares_number"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_sydel_contact_shareholding_form" model="ir.ui.view">
        <field name="name">sydel.contact.shareholding.form</field>
        <field name="model">sydel.contact.shareholding</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="shareholder_partner_id"/>
                        <field name="company_partner_id"/>
                        <field name="percentage"/>
                        <field name="shares_number"/>
                        <field name="active"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sydel_contact_shareholding_search" model="ir.ui.view">
        <field name="name">sydel.contact.shareholding.search</field>
        <field name="model">sydel.contact.shareholding</field>
        <field name="arch" type="xml">
            <search>
                <field name="shareholder_partner_id"/>
                <field name="company_partner_id"/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
            </search>
        </field>
    </record>

    <record id="action_sydel_contact_shareholding" model="ir.actions.act_window">
        <field name="name">Shareholdings</field>
        <field name="res_model">sydel.contact.shareholding</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

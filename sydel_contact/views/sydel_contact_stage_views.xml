<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sydel_contact_stage_list" model="ir.ui.view">
        <field name="name">sydel.contact.stage.list</field>
        <field name="model">sydel.contact.stage</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="fold"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_sydel_contact_stage_form" model="ir.ui.view">
        <field name="name">sydel.contact.stage.form</field>
        <field name="model">sydel.contact.stage</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="fold"/>
                        <field name="active"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sydel_contact_stage_search" model="ir.ui.view">
        <field name="name">sydel.contact.stage.search</field>
        <field name="model">sydel.contact.stage</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
            </search>
        </field>
    </record>

    <record id="action_sydel_contact_stage" model="ir.actions.act_window">
        <field name="name">Contact Stages</field>
        <field name="res_model">sydel.contact.stage</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

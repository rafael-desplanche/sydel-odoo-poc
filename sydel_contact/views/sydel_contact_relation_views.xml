<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sydel_contact_relation_list" model="ir.ui.view">
        <field name="name">sydel.contact.relation.list</field>
        <field name="model">sydel.contact.relation</field>
        <field name="arch" type="xml">
            <list>
                <field name="left_partner_id"/>
                <field name="relation_type_id"/>
                <field name="right_partner_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_sydel_contact_relation_form" model="ir.ui.view">
        <field name="name">sydel.contact.relation.form</field>
        <field name="model">sydel.contact.relation</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="left_partner_id"/>
                        <field name="relation_type_id"/>
                        <field name="right_partner_id"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="active"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sydel_contact_relation_search" model="ir.ui.view">
        <field name="name">sydel.contact.relation.search</field>
        <field name="model">sydel.contact.relation</field>
        <field name="arch" type="xml">
            <search>
                <field name="left_partner_id"/>
                <field name="right_partner_id"/>
                <field name="relation_type_id"/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
            </search>
        </field>
    </record>

    <record id="action_sydel_contact_relation" model="ir.actions.act_window">
        <field name="name">Relations</field>
        <field name="res_model">sydel.contact.relation</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

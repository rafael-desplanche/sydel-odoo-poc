<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sydel_contact_management_list" model="ir.ui.view">
        <field name="name">sydel.contact.management.list</field>
        <field name="model">sydel.contact.management</field>
        <field name="arch" type="xml">
            <list>
                <field name="partner_id"/>
                <field name="manager_partner_id"/>
                <field name="role"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="view_sydel_contact_management_form" model="ir.ui.view">
        <field name="name">sydel.contact.management.form</field>
        <field name="model">sydel.contact.management</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="partner_id"/>
                        <field name="manager_partner_id"/>
                        <field name="role"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="is_active"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sydel_contact_management_search" model="ir.ui.view">
        <field name="name">sydel.contact.management.search</field>
        <field name="model">sydel.contact.management</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="manager_partner_id"/>
                <field name="role"/>
                <filter name="active" string="Active" domain="[('is_active', '=', True)]"/>
            </search>
        </field>
    </record>

    <record id="action_sydel_contact_management" model="ir.actions.act_window">
        <field name="name">Governance</field>
        <field name="res_model">sydel.contact.management</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
